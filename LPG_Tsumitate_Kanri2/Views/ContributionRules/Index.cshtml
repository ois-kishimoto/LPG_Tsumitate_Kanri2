@model IEnumerable<LPG_Tsumitate_Kanri2.Models.Entities.ContributionAmountRule>
@{
    ViewData["Title"] = "積立金額ルール";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>積立金額ルール</h2>
    <a asp-action="Create" class="btn btn-primary">＋ ルール追加</a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>種別</th>
                <th>優先順位</th>
                <th>条件</th>
                <th class="text-end">月額</th>
                <th>有効開始</th>
                <th>有効終了</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr class="@(r.ValidTo.HasValue && r.ValidTo < DateOnly.FromDateTime(DateTime.Today) ? "text-muted" : "")">
                    <td>@r.SavingsType.Name</td>
                    <td>@r.Priority</td>
                    <td>@r.ConditionSummary</td>
                    <td class="text-end fw-semibold">@r.Amount.ToString("N0") 円</td>
                    <td>@r.ValidFrom.ToString("yyyy/MM/dd")</td>
                    <td>@(r.ValidTo?.ToString("yyyy/MM/dd") ?? "—")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@r.RuleId" class="btn btn-sm btn-outline-secondary">編集</a>
                        <form asp-action="Delete" asp-route-id="@r.RuleId" method="post" class="d-inline"
                              onsubmit="return confirm('削除しますか？')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">削除</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
