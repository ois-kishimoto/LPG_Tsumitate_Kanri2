@model LPG_Tsumitate_Kanri2.Models.Entities.LedgerEntry
@{
    ViewData["Title"] = "収支詳細";
}

<div class="d-flex flex-wrap gap-2 justify-content-between align-items-start mb-4">
    <h2>収支詳細</h2>
    <a asp-action="Index" asp-route-savingsTypeId="@Model.SavingsTypeId" class="btn btn-outline-secondary btn-sm">← 一覧に戻る</a>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <table class="table table-bordered">
            <tr><th class="table-light" style="width:35%">日付</th><td>@Model.TransactionDate.ToString("yyyy年MM月dd日")</td></tr>
            <tr><th class="table-light">種別</th><td>@Model.SavingsType.Name</td></tr>
            <tr><th class="table-light">区分</th>
                <td>
                    <span class="badge bg-@(Model.EntryType == "入金" ? "success" : "danger")">@Model.EntryType</span>
                    @if (Model.IsAutoGenerated)
                    {
                        <span class="badge bg-light text-dark border ms-1">自動生成</span>
                    }
                </td>
            </tr>
            <tr><th class="table-light">内容</th><td>@Model.Description</td></tr>
            <tr><th class="table-light">金額</th><td class="fw-bold">@Model.Amount.ToString("N0") 円</td></tr>
            <tr><th class="table-light">残高</th><td>@Model.BalanceAfter.ToString("N0") 円</td></tr>
            @if (Model.Notes != null)
            {
                <tr><th class="table-light">備考</th><td>@Model.Notes</td></tr>
            }
        </table>
    </div>
</div>

<h5 class="mb-3">領収書</h5>

@if (Model.Receipts.Any())
{
    <div class="row g-3 mb-3">
        @foreach (var r in Model.Receipts)
        {
            <div class="col-6 col-sm-auto">
                <div class="card h-100">
                    <div class="card-body text-center py-3">
                        <div class="mb-2">
                            @if (r.ContentType.StartsWith("image/"))
                            {
                                <a href="#" class="receipt-img-trigger"
                                   data-img-src="@Url.Action("View", "Receipts", new { id = r.ReceiptId })"
                                   data-bs-toggle="modal" data-bs-target="#receiptModal">
                                    <img src="@Url.Action("View", "Receipts", new { id = r.ReceiptId })"
                                         style="max-width:100%;max-height:120px;object-fit:cover" alt="領収書" />
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Receipts" asp-action="View" asp-route-id="@r.ReceiptId" target="_blank"
                                   class="btn btn-outline-secondary btn-sm">PDF を開く</a>
                            }
                        </div>
                        <small class="text-muted d-block text-truncate" title="@r.OriginalFileName">@r.OriginalFileName</small>
                        <div class="d-flex justify-content-center gap-2 mt-1">
                            <form asp-controller="Receipts" asp-action="Delete" asp-route-id="@r.ReceiptId" method="post"
                                  onsubmit="return confirm('削除しますか？')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-link text-danger p-0">削除</button>
                            </form>
                            <a asp-controller="Receipts" asp-action="Download" asp-route-id="@r.ReceiptId"
                               class="btn btn-sm btn-link text-primary p-0">ダウンロード</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">領収書がアップロードされていません。</p>
}

<form asp-controller="Receipts" asp-action="Upload" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="entryId" value="@Model.EntryId" />
    <div class="input-group" style="max-width:400px">
        <input type="file" name="file" accept="image/jpeg,image/png,image/gif,application/pdf"
               class="form-control form-control-sm" />
        <button type="submit" class="btn btn-sm btn-outline-primary">アップロード</button>
    </div>
    <small class="text-muted">JPEG・PNG・PDF、10MB以下</small>
</form>

<div class="modal fade" id="receiptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title mb-0">領収書</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
            </div>
            <div class="modal-body text-center p-2">
                <img id="receiptModalImg" src="" style="max-width:100%;max-height:80vh;object-fit:contain" alt="領収書" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.receipt-img-trigger').forEach(function (a) {
        a.addEventListener('click', function () {
            document.getElementById('receiptModalImg').src = this.dataset.imgSrc;
        });
    });
</script>
}
