@model IEnumerable<LPG_Tsumitate_Kanri2.Models.Entities.LedgerEntry>
@{
    ViewData["Title"] = "収支帳簿";
    var savingsTypes = (List<LPG_Tsumitate_Kanri2.Models.Entities.SavingsType>)ViewBag.SavingsTypes;
    int? filterSavingsTypeId = ViewBag.FilterSavingsTypeId;
    int? filterYear = ViewBag.FilterYear;
    int? filterMonth = ViewBag.FilterMonth;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>収支帳簿</h2>
    <a asp-action="Create" class="btn btn-primary">＋ 収支入力</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-auto">
        <select name="savingsTypeId" class="form-select form-select-sm">
            <option value="">全種別</option>
            @foreach (var st in savingsTypes)
            {
                <option value="@st.SavingsTypeId" selected="@(filterSavingsTypeId == st.SavingsTypeId)">@st.Name</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <input type="number" name="year" value="@filterYear" placeholder="年" class="form-control form-control-sm" style="width:90px" />
    </div>
    <div class="col-auto">
        <input type="number" name="month" value="@filterMonth" placeholder="月" class="form-control form-control-sm" style="width:70px" min="1" max="12" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-secondary">絞り込み</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover table-sm">
        <thead class="table-light">
            <tr>
                <th>日付</th>
                <th>種別</th>
                <th>区分</th>
                <th>内容</th>
                <th class="text-end">収入</th>
                <th class="text-end">支出</th>
                <th class="text-end">残高</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td class="text-nowrap">@e.TransactionDate.ToString("yyyy/MM/dd")</td>
                    <td>@e.SavingsType.Name</td>
                    <td>
                        <span class="badge bg-@(e.EntryType == "入金" ? "success" : "danger")">@e.EntryType</span>
                        @if (e.IsAutoGenerated)
                        {
                            <span class="badge bg-light text-dark border">自動</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@e.EntryId">@e.Description</a>
                    </td>
                    <td class="text-end text-success">
                        @(e.EntryType == "入金" ? e.Amount.ToString("N0") + " 円" : "")
                    </td>
                    <td class="text-end text-danger">
                        @(e.EntryType == "出金" ? e.Amount.ToString("N0") + " 円" : "")
                    </td>
                    <td class="text-end fw-semibold">@e.BalanceAfter.ToString("N0") 円</td>
                    <td class="text-end text-nowrap">
                        @if (!e.IsAutoGenerated)
                        {
                            <a asp-action="Edit" asp-route-id="@e.EntryId" class="btn btn-sm btn-outline-secondary">編集</a>
                            <form asp-action="Delete" asp-route-id="@e.EntryId" method="post" class="d-inline"
                                  onsubmit="return confirm('削除しますか？後続レコードの残高が再計算されます。')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">削除</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted text-center py-4">収支記録がありません。</p>
}
