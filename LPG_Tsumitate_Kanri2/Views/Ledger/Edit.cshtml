@model LPG_Tsumitate_Kanri2.Models.ViewModels.LedgerFormViewModel
@{
    ViewData["Title"] = "収支編集";
}

<h2 class="mb-4">収支編集</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.EntryId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EntryId" />
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            }

            <div class="mb-3">
                <label asp-for="SavingsTypeId" class="form-label"></label>
                <select asp-for="SavingsTypeId" class="form-select">
                    @foreach (var st in Model.SavingsTypes)
                    {
                        <option value="@st.SavingsTypeId">@st.Name</option>
                    }
                </select>
                <span asp-validation-for="SavingsTypeId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TransactionDate" class="form-label"></label>
                <input asp-for="TransactionDate" type="date" class="form-control" />
                <span asp-validation-for="TransactionDate" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="EntryType" class="form-label"></label>
                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input type="radio" asp-for="EntryType" value="入金" class="form-check-input" id="entryTypeIn" />
                        <label class="form-check-label text-success" for="entryTypeIn">入金</label>
                    </div>
                    <div class="form-check">
                        <input type="radio" asp-for="EntryType" value="出金" class="form-check-input" id="entryTypeOut" />
                        <label class="form-check-label text-danger" for="entryTypeOut">出金</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Amount" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="Amount" type="number" class="form-control" min="1" />
                    <span class="input-group-text">円</span>
                </div>
                <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">更新</button>
                <a asp-action="Index" class="btn btn-outline-secondary">キャンセル</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
