@model IEnumerable<LPG_Tsumitate_Kanri2.Models.Entities.CollectionSession>
@{
    ViewData["Title"] = "徴収管理";
    var savingsTypes = (List<LPG_Tsumitate_Kanri2.Models.Entities.SavingsType>)ViewBag.SavingsTypes;
    int? filterYear = ViewBag.FilterYear;
    int? filterSavingsTypeId = ViewBag.FilterSavingsTypeId;
}

<div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
    <h2>徴収管理</h2>
    <a asp-action="Create" class="btn btn-primary">＋ 新規セッション作成</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-12 col-sm-auto">
        <select name="savingsTypeId" class="form-select form-select-sm">
            <option value="">全種別</option>
            @foreach (var st in savingsTypes)
            {
                <option value="@st.SavingsTypeId" selected="@(filterSavingsTypeId == st.SavingsTypeId)">@st.Name</option>
            }
        </select>
    </div>
    <div class="col-6 col-sm-auto">
        <input type="number" name="year" value="@filterYear" placeholder="年" class="form-control form-control-sm w-100" />
    </div>
    <div class="col-6 col-sm-auto">
        <button type="submit" class="btn btn-sm btn-outline-secondary w-100">絞り込み</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>対象月</th>
                <th>種別</th>
                <th>開催日</th>
                <th class="text-center">徴収済</th>
                <th class="text-center">未徴収</th>
                <th class="text-center">除外</th>
                <th class="text-center">状態</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                var collected = s.CollectionRecords.Count(r => r.IsCollected && !r.IsExcluded);
                var pending = s.CollectionRecords.Count(r => !r.IsCollected && !r.IsExcluded);
                var excluded = s.CollectionRecords.Count(r => r.IsExcluded);
                <tr>
                    <td>@s.Year 年 @s.Month 月</td>
                    <td>@s.SavingsType.Name</td>
                    <td>@(s.SessionDate?.ToString("yyyy/MM/dd") ?? "—")</td>
                    <td class="text-center">@collected 人</td>
                    <td class="text-center text-@(pending > 0 ? "danger" : "muted")">@pending 人</td>
                    <td class="text-center text-muted">@excluded 人</td>
                    <td class="text-center">
                        @if (s.IsCompleted)
                        {
                            <span class="badge bg-success">締め切り済</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">進行中</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@s.SessionId" class="btn btn-sm btn-outline-primary">チェック画面</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted text-center py-4">セッションがありません。</p>
}
